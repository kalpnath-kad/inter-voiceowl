# Application Port
# Default: 3000
PORT=3000

# MongoDB Connection URI
# Format: mongodb://[username:password@]host[:port][/database][?options]
# Example for local development:
MONGODB_URI=mongodb://localhost:27017/voiceowl

# Example for MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/voiceowl?retryWrites=true&w=majority

# Example with authentication:
# MONGODB_URI=mongodb://username:password@localhost:27017/voiceowl?authSource=admin
